<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProfile name="prod,staging">
    <!-- Structured JSON logging for production -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>requestId</includeMdcKeyName>
        <includeMdcKeyName>method</includeMdcKeyName>
        <includeMdcKeyName>uri</includeMdcKeyName>
        <customFields>{"app":"springboot-cicd","env":"${SPRING_PROFILES_ACTIVE:-unknown}"}</customFields>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>
  </springProfile>

  <springProfile name="!prod,!staging">
    <!-- Human-readable logging for dev/test -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{requestId:-}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.devops.app" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
  </springProfile>
</configuration>
