{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Spring Boot 3 Application Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job='springboot-cicd'}[5m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job='springboot-cicd',status=~'5..'}[5m])",
          "legendFormat": "5xx errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job='springboot-cicd'}[5m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job='springboot-cicd',area='heap'}",
          "legendFormat": "Used Heap"
        },
        {
          "expr": "jvm_memory_max_bytes{job='springboot-cicd',area='heap'}",
          "legendFormat": "Max Heap"
        }
      ]
    },
    {
      "id": 5,
      "title": "Task Count by Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "tasks_count{job='springboot-cicd'}",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active DB Connections (HikariCP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job='springboot-cicd'}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{job='springboot-cicd'}",
          "legendFormat": "Idle"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job='springboot-cicd'}[5m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["spring-boot", "java", "cicd"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Spring Boot CI/CD Dashboard",
  "uid": "springboot-cicd-main",
  "version": 1
}
